# Copy to .env.local and fill in real values. Never commit real secrets.

# --- Ringg AI (required to place calls) ---
RINGG_API_KEY=your-ringg-api-key
RINGG_AGENT_ID=your-agent-id              # from GET /agent/all
RINGG_FROM_NUMBER_ID=your-from-number-id  # from GET /workspace/numbers

# --- Neon Postgres (required for persistence) ---
DATABASE_URL=postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require&channel_binding=require

# --- Neon Auth (@neondatabase/auth) ---
# Auth URL from Neon Console → Auth → Configuration. Secret: openssl rand -base64 32
NEON_AUTH_BASE_URL=https://YOUR-ENDPOINT.neonauth.REGION.aws.neon.tech/DB/auth
NEON_AUTH_COOKIE_SECRET=a-32+-char-random-string

# --- Webhook (production only) ---
# Public app URL so Ringg can call back. Leave empty on localhost (use polling instead).
PUBLIC_BASE_URL=https://your-app.vercel.app
RINGG_WEBHOOK_SECRET=your-webhook-secret

# --- Cron (daily enqueue) ---
CRON_SECRET=your-cron-secret

# --- Web Push (generate: npx web-push generate-vapid-keys) ---
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:you@example.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
